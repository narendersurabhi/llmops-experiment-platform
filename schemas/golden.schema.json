{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["dataset_name", "dataset_version", "benchmark_prompts"],
  "properties": {
    "dataset_name": {"type": "string"},
    "dataset_version": {"type": "string"},
    "description": {"type": "string"},
    "benchmark_prompts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "suite", "prompt"],
        "properties": {
          "id": {"type": "string"},
          "suite": {
            "type": "string",
            "enum": ["public", "domain"]
          },
          "prompt": {"type": "string"},
          "reference_answer": {"type": "string"},
          "expected_keywords": {
            "type": "array",
            "items": {"type": "string"}
          },
          "minimum_response_chars": {
            "type": "integer",
            "minimum": 1
          },
          "system_prompt": {"type": "string"},
          "max_new_tokens": {
            "type": "integer",
            "minimum": 1
          },
          "temperature": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    }
  }
}
